{
    "name": "traviscarden/behat-table-comparison",
    "description": "Provides an equality assertion for comparing Behat TableNode tables.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "Behat",
        "Gherkin"
    ],
    "authors": [
        {
            "name": "Travis Carden",
            "email": "travis.carden@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "behat/gherkin": "^4.11"
    },
    "require-dev": {
        "behat/behat": "^3.16",
        "ergebnis/composer-normalize": "^2.50",
        "phpunit/phpunit": "^12.0",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "TravisCarden\\BehatTableComparison\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TravisCarden\\BehatTableComparison\\Examples\\Bootstrap\\": "examples/bootstrap/",
            "TravisCarden\\BehatTableComparison\\Tests\\Behat\\Bootstrap\\": "tests/behat/bootstrap/",
            "TravisCarden\\BehatTableComparison\\Tests\\Unit\\": "tests/unit/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        },
        "sort-packages": true
    },
    "scripts": {
        "check:all": [
            "@check:fast",
            "composer audit"
        ],
        "check:behat": [
            "@check:behat-integration",
            "@check:behat-examples"
        ],
        "check:behat-examples": "behat -c examples/behat.yml --no-interaction --format=progress",
        "check:behat-integration": "behat -c tests/behat.yml --no-interaction --format=progress",
        "check:fast": [
            "@check:test",
            "@check:static"
        ],
        "check:phpcbf": "phpcbf",
        "check:phpcs": "phpcs -s",
        "check:phpunit": "phpunit",
        "check:static": [
            "@check:phpcs",
            "composer validate",
            "composer normalize --dry-run"
        ],
        "check:test": [
            "@check:phpunit",
            "@check:behat"
        ],
        "docker:build": "docker compose build",
        "docker:check-fast-83": "docker compose run --rm php83",
        "docker:check-fast-84": "docker compose run --rm php84",
        "docker:check-fast-85": "docker compose run --rm php85",
        "docker:check-fast-all": [
            "@docker:check-fast-83",
            "@docker:check-fast-84",
            "@docker:check-fast-85"
        ],
        "docker:down": "docker compose down"
    },
    "scripts-descriptions": {
        "check:all": "Runs fast checks plus dependency audit (audit may make HTTP requests)",
        "check:behat": "Runs Behat integration tests and executable examples",
        "check:behat-examples": "Runs Behat executable examples",
        "check:behat-integration": "Runs Behat integration tests",
        "check:fast": "Runs all tests and static analysis tools (no dependency audit)",
        "check:phpcbf": "Automatically fixes standards violations where possible",
        "check:phpcs": "Checks code for standards compliance",
        "check:phpunit": "Runs automated tests",
        "check:static": "Runs all static analysis tools",
        "check:test": "Runs all tests",
        "docker:build": "Builds the Docker images for all supported PHP versions",
        "docker:check-fast-83": "Runs check:fast inside the PHP 8.3 Docker container",
        "docker:check-fast-84": "Runs check:fast inside the PHP 8.4 Docker container",
        "docker:check-fast-85": "Runs check:fast inside the PHP 8.5 Docker container",
        "docker:check-fast-all": "Runs check:fast across all supported PHP versions via Docker",
        "docker:down": "Stops and removes Docker containers and networks (images and volumes are preserved; no rebuild needed to resume)"
    },
    "scripts-aliases": {
        "check:all": [
            "all"
        ],
        "check:behat": [
            "behat"
        ],
        "check:behat-examples": [
            "behat-examples",
            "examples"
        ],
        "check:behat-integration": [
            "behat-integration",
            "integration"
        ],
        "check:fast": [
            "fast"
        ],
        "check:phpcbf": [
            "phpcbf",
            "cbf",
            "fix"
        ],
        "check:phpcs": [
            "phpcs",
            "cs"
        ],
        "check:phpunit": [
            "phpunit"
        ],
        "check:static": [
            "static"
        ],
        "check:test": [
            "test"
        ],
        "docker:build": [
            "build"
        ],
        "docker:check-fast-83": [
            "docker-fast-83",
            "docker-83",
            "83"
        ],
        "docker:check-fast-84": [
            "docker-fast-84",
            "docker-84",
            "84"
        ],
        "docker:check-fast-85": [
            "docker-fast-85",
            "docker-85",
            "85"
        ],
        "docker:check-fast-all": [
            "docker-fast-all",
            "docker-fast"
        ],
        "docker:down": [
            "down"
        ]
    }
}
