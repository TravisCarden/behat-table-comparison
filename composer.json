{
    "name": "traviscarden/behat-table-comparison",
    "description": "Provides an equality assertion for comparing Behat TableNode tables.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "Behat",
        "Gherkin"
    ],
    "authors": [
        {
            "name": "Travis Carden",
            "email": "travis.carden@gmail.com"
        }
    ],
    "require": {
        "php": "^7.3 || ^8.0",
        "behat/gherkin": "^4.4.4"
    },
    "require-dev": {
        "behat/behat": "^3.3",
        "ergebnis/composer-normalize": "^2.50",
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "TravisCarden\\BehatTableComparison\\": "src/BehatTableComparison/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TravisCarden\\BehatTableComparison\\Examples\\": "examples/",
            "TravisCarden\\BehatTableComparison\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        },
        "sort-packages": true
    },
    "scripts": {
        "check:all": [
            "@check:fast",
            "composer audit"
        ],
        "check:behat": [
            "@check:behat-integration",
            "@check:behat-examples"
        ],
        "check:behat-examples": "behat -c examples/behat.yml --no-interaction --format=progress",
        "check:behat-integration": "behat -c tests/behat.yml --no-interaction --format=progress",
        "check:fast": [
            "@check:test",
            "@check:static"
        ],
        "check:phpcbf": "phpcbf",
        "check:phpcs": "phpcs -s",
        "check:phpunit": "phpunit",
        "check:static": [
            "@check:phpcs",
            "composer validate",
            "composer normalize --dry-run"
        ],
        "check:test": [
            "@check:phpunit",
            "@check:behat"
        ]
    },
    "scripts-descriptions": {
        "check:all": "Runs fast checks plus dependency audit (audit may make HTTP requests)",
        "check:behat": "Runs Behat integration tests and executable examples",
        "check:behat-examples": "Runs Behat executable examples",
        "check:behat-integration": "Runs Behat integration tests",
        "check:fast": "Runs all tests and static analysis tools (no dependency audit)",
        "check:phpcbf": "Automatically fixes standards violations where possible",
        "check:phpcs": "Checks code for standards compliance",
        "check:phpunit": "Runs automated tests",
        "check:static": "Runs all static analysis tools",
        "check:test": "Runs all tests"
    },
    "scripts-aliases": {
        "check:all": [
            "all"
        ],
        "check:behat": [
            "behat"
        ],
        "check:behat-examples": [
            "behat-examples",
            "examples"
        ],
        "check:behat-integration": [
            "behat-integration",
            "integration"
        ],
        "check:fast": [
            "fast"
        ],
        "check:phpcbf": [
            "phpcbf",
            "cbf",
            "fix"
        ],
        "check:phpcs": [
            "phpcs",
            "cs"
        ],
        "check:phpunit": [
            "phpunit"
        ],
        "check:static": [
            "static"
        ],
        "check:test": [
            "test"
        ]
    }
}
