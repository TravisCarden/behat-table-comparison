{
    "name": "traviscarden/behat-table-comparison",
    "description": "Provides an equality assertion for comparing Behat TableNode tables.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "Behat",
        "Gherkin"
    ],
    "authors": [
        {
            "name": "Travis Carden",
            "email": "travis.carden@gmail.com"
        }
    ],
    "require": {
        "php": "^7.3 || ^8.0",
        "behat/gherkin": "^4.4.4"
    },
    "require-dev": {
        "behat/behat": "^3.3",
        "ergebnis/composer-normalize": "^2.50",
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "TravisCarden\\BehatTableComparison\\": "src/BehatTableComparison/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        },
        "sort-packages": true
    },
    "scripts": {
        "all": [
            "@fast",
            "composer audit"
        ],
        "behat": "behat --no-interaction --format=progress",
        "fast": [
            "@test",
            "@static"
        ],
        "phpcbf": "phpcbf",
        "phpcs": "phpcs -s",
        "phpunit": "phpunit",
        "static": [
            "@phpcs",
            "composer validate",
            "composer normalize --dry-run"
        ],
        "test": [
            "@phpunit",
            "@behat"
        ]
    },
    "scripts-descriptions": {
        "all": "Runs fast checks plus dependency audit (audit may make HTTP requests)",
        "behat": "Runs Behat integration tests",
        "fast": "Runs all tests and static analysis tools (no dependency audit)",
        "phpcbf": "Automatically fixes standards violations where possible",
        "phpcs": "Checks code for standards compliance",
        "phpunit": "Runs automated tests",
        "static": "Runs all static analysis tools",
        "test": "Runs all tests"
    },
    "scripts-aliases": {
        "phpcbf": [
            "cbf",
            "fix"
        ],
        "phpcs": [
            "cs"
        ]
    }
}
